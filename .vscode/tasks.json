{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Strictify: Lint Example",
      "type": "shell",
      "command": "${workspaceFolder}\\build\\Debug\\strictify.exe",
      "args": [
        "${workspaceFolder}\\..\\Example",
        "${workspaceFolder}\\..\\Example\\src"
      ],
      "group": "test",
      "problemMatcher": {
        "owner": "strictify",
        "fileLocation": [
          "relative",
          "${workspaceFolder}\\..\\Example"
        ],
        "pattern": {
          "regexp": "^(.*\\.md):\\s(.+)$",
          "file": 1,
          "message": 2
        }
      }
    },
    {
      "label": "Strictify: Lint Current File",
      "type": "shell",
      "command": "${workspaceFolder}\\Strictify\\build\\Debug\\strictify.exe",
      "args": [
        "${file}",
      ],
      "group": "test",
      "problemMatcher": {
        "owner": "strictify",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(.*\\.md):\\s(.+)$",
          "file": 1,
          "message": 2
        }
      }
    }
  ]
}
